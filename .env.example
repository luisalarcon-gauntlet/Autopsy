# Autopsy Environment Configuration
# Copy this to .env and fill in values
# NEVER commit .env to git

# Required: Anthropic API key for Claude analysis
# Get one at: https://console.anthropic.com/
# If not set, app runs in stub mode (pre-canned responses)
ANTHROPIC_API_KEY=

# Optional: Server port (default: 8080)
PORT=8080

# Optional: Maximum bundle upload size in MB (default: 250)
MAX_BUNDLE_MB=250

# Optional: Force stub mode even if API key is set (for testing)
STUB_MODE=false

# Optional: Session TTL in minutes (default: 30)
SESSION_TTL_MINUTES=30

# Optional: Analysis cache TTL in hours (default: 2)
CACHE_TTL_HOURS=2
